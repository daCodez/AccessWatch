<Window x:Class="AccessWatch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AccessWatch" Height="760" Width="1280" MinHeight="680" MinWidth="1120"
        Background="#F6F8FA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="0,0,0,1" Padding="20,14">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="AccessWatch" FontSize="22" FontWeight="SemiBold" Foreground="#24292F" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#2DA44E" Margin="0,0,8,0" />
                    <TextBlock Text="Ready" Foreground="#57606A" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="0,0,1,0" Padding="12">
                <ListBox ItemsSource="{Binding Pages}"
                         SelectedItem="{Binding SelectedPage, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#24292F" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Summary}" Margin="0,3,0,0" FontSize="11" Foreground="#57606A" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Column="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,18">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="{Binding ScanButtonText}" IsEnabled="{Binding CanRunActions}" Width="112" Height="32" Margin="0,0,8,0" Click="OnScanNowClick" />
                        <Button Content="{Binding SimulateButtonText}" IsEnabled="{Binding CanRunActions}" Width="120" Height="32" Margin="0,0,8,0" Click="OnSimulateEventClick" />
                        <Button Content="{Binding RefreshButtonText}" IsEnabled="{Binding CanRunActions}" Width="104" Height="32" Click="OnRefreshClick" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedPageTitle}" FontSize="26" FontWeight="SemiBold" Foreground="#24292F" />
                        <TextBlock Text="{Binding StatusMessage}" Margin="0,6,16,0" FontSize="14" Foreground="#57606A" TextWrapping="Wrap" />
                        <StackPanel Margin="0,10,16,0" Visibility="{Binding LoadingVisibility}">
                            <ProgressBar Height="4" Width="320" HorizontalAlignment="Left" IsIndeterminate="True" />
                            <TextBlock Text="{Binding ProgressMessage}" Margin="0,6,0,0" FontSize="12" Foreground="#57606A" />
                        </StackPanel>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,18" Visibility="{Binding OverviewVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Simple mode is on" Foreground="#57606A" FontSize="12" />
                            <TextBlock Text="{Binding SafetyHeadline}" Foreground="#24292F" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SafetyExplanation}" Foreground="#57606A" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SafetyRecommendation}" Foreground="#24292F" FontSize="13" FontWeight="SemiBold" Margin="0,12,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Expander Grid.Column="2" Header="Show counts" IsExpanded="False" VerticalAlignment="Top">
                        <ItemsControl ItemsSource="{Binding Metrics}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,8,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="#57606A" FontSize="12" />
                                            <TextBlock Text="{Binding Count}" Foreground="#24292F" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </Grid>

                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18" Visibility="{Binding OverviewVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Things that need your attention" FontSize="18" FontWeight="SemiBold" Foreground="#24292F" />
                        <Border Grid.Row="1" Margin="0,12,0,0" Padding="12" Background="#EAF7EF" BorderBrush="#2DA44E" BorderThickness="1" CornerRadius="6" Visibility="{Binding ToastVisibility}">
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right" Content="Dismiss" Width="76" Height="28" Margin="12,0,0,0" Click="OnDismissToastClick" />
                                <TextBlock Text="{Binding ToastMessage}" Foreground="#1A7F37" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <Border Grid.Row="2" Margin="0,14,0,0" Padding="22" Background="#F6F8FA" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Visibility="{Binding SafetyEmptyVisibility}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Nothing needs action" FontSize="18" FontWeight="SemiBold" Foreground="#24292F" HorizontalAlignment="Center" />
                                <TextBlock Text="AccessWatch will show plain alerts here when something needs your attention." FontSize="13" Foreground="#57606A" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ListView Grid.Row="2" ItemsSource="{Binding SafetyItems}" Margin="0,10,0,0" BorderThickness="0" Visibility="{Binding SafetyItemsVisibility}" HorizontalContentAlignment="Stretch">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="240" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Urgency}" Foreground="#0969DA" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                            <TextBlock Text="{Binding Headline}" Foreground="#24292F" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Target}" Foreground="#57606A" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                                            <Expander Header="Why am I seeing this?" IsExpanded="False" Margin="0,8,0,0">
                                                <StackPanel Margin="0,6,0,0">
                                                    <TextBlock Text="What happened" Foreground="#57606A" FontSize="11" />
                                                    <TextBlock Text="{Binding WhatHappened}" Foreground="#57606A" FontSize="13" Margin="0,2,0,8" TextWrapping="Wrap" />
                                                    <TextBlock Text="What to do" Foreground="#57606A" FontSize="11" />
                                                    <TextBlock Text="{Binding RecommendedAction}" Foreground="#24292F" FontSize="13" Margin="0,2,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <Button Content="{Binding PrimaryAction}" Width="96" Height="30" Margin="0,0,8,0" Click="OnSafetyPrimaryActionClick" />
                                            <Button Content="{Binding SecondaryAction}" Width="96" Height="30" Click="OnSafetySecondaryActionClick" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Expander Grid.Row="3" Header="Show technical activity" Margin="0,14,0,0" IsExpanded="False">
                            <ListView ItemsSource="{Binding RecentActivity}" Margin="0,8,0,0" BorderThickness="0" MaxHeight="220">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="82" />
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Kind}" Foreground="#0969DA" FontWeight="SemiBold" />
                                            <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                                <TextBlock Text="{Binding ApplicationName}" Foreground="#24292F" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding ApplicationIdentity}" Foreground="#57606A" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Summary}" Foreground="#24292F" FontSize="14" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Detail}" Foreground="#57606A" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding WhyItMatters, StringFormat=Why: {0}}" Foreground="#57606A" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding SuggestedAction, StringFormat=Action: {0}}" Foreground="#57606A" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Expander>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18" Visibility="{Binding DevicesVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DataGrid ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column" CanUserAddRows="False" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Device" Binding="{Binding Name}" Width="220" MinWidth="180" />
                                <DataGridTextColumn Header="Name source" Binding="{Binding NameSource}" Width="130" />
                                <DataGridTextColumn Header="IP address" Binding="{Binding IpAddress}" Width="130" />
                                <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="150" />
                                <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="150" />
                                <DataGridTextColumn Header="Trust" Binding="{Binding TrustStatus}" Width="90" />
                                <DataGridTextColumn Header="Risk" Binding="{Binding RiskStatus}" Width="90" />
                                <DataGridTextColumn Header="State" Binding="{Binding InventoryState}" Width="130" />
                                <DataGridTextColumn Header="First seen" Binding="{Binding FirstSeen}" Width="130" />
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="130" />
                                <DataGridTextColumn Header="Confirmed" Binding="{Binding LastConfirmed}" Width="130" />
                                <DataGridTextColumn Header="Next step" Binding="{Binding RecommendedAction}" Width="2*" />
                                <DataGridTextColumn Header="Details" Binding="{Binding Detail}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="1" BorderBrush="#D0D7DE" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,10">
                                    <UniformGrid Columns="6" Margin="0,0,0,8">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Device" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedDevice.Name}" FontSize="13" FontWeight="SemiBold" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="IP address" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedDevice.IpAddress}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Trust" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedDevice.TrustStatus}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Risk" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedDevice.RiskStatus}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="State" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedDevice.InventoryState}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Last seen" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedDevice.LastSeen}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="Next step" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedDevice.RecommendedAction}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,6" />
                                    <TextBlock Text="Details" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedDevice.Detail}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <WrapPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button Content="This is OK" IsEnabled="{Binding CanApplyDeviceTrustDecision}" Width="96" Height="30" Margin="0,0,8,8" Click="OnTrustDeviceClick" />
                                    <Button Content="Keep watching" IsEnabled="{Binding CanApplyDeviceTrustDecision}" Width="104" Height="30" Margin="0,0,8,8" Click="OnWatchDeviceClick" />
                                    <Button Content="Block it" IsEnabled="{Binding CanApplyDeviceTrustDecision}" Width="96" Height="30" Margin="0,0,8,8" Click="OnBlockDeviceClick" />
                                </WrapPanel>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Alias" Foreground="#57606A" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox Text="{Binding SelectedDeviceAlias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanApplyDeviceTrustDecision}" Width="220" Height="30" Margin="0,0,8,0" />
                                    <Button Content="Save alias" IsEnabled="{Binding CanApplyDeviceTrustDecision}" Width="88" Height="30" Margin="0,0,8,0" Click="OnSaveDeviceAliasClick" />
                                    <Button Content="Clear" IsEnabled="{Binding CanApplyDeviceTrustDecision}" Width="64" Height="30" Click="OnClearDeviceAliasClick" />
                                </StackPanel>
                                <Expander Grid.Row="3" Header="Show device tools" IsExpanded="False" Margin="0,12,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,8">
                                            <Button Content="Mark as guest" IsEnabled="{Binding CanApplyDeviceTrustDecision}" Width="104" Height="30" Margin="0,0,8,8" Click="OnGuestDeviceClick" />
                                            <Button Content="Trace device" IsEnabled="{Binding CanTraceSelectedDevice}" Width="104" Height="30" Margin="0,0,8,8" Click="OnTraceDeviceClick" />
                                            <Button Content="Apply protection" IsEnabled="{Binding CanApplyEnforcementPlan}" Width="124" Height="30" Margin="0,0,0,8" Click="OnApplyProtectionClick" />
                                        </WrapPanel>
                                        <TextBlock Text="Trace result" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding SelectedDeviceTrace, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontFamily="Consolas" FontSize="12" />
                                        <TextBlock Text="Protection plan" FontSize="11" Foreground="#57606A" Margin="0,10,0,4" />
                                        <TextBox Text="{Binding SelectedEnforcementPlan, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontFamily="Consolas" FontSize="12" />
                                    </StackPanel>
                                </Expander>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18" Visibility="{Binding ApplicationsVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DataGrid ItemsSource="{Binding Applications}" SelectedItem="{Binding SelectedApplication, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column" CanUserAddRows="False" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Application" Binding="{Binding Name}" Width="1.5*" />
                                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="130" />
                                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="1.2*" />
                                <DataGridTextColumn Header="Signature" Binding="{Binding SignatureStatus}" Width="150" />
                                <DataGridTextColumn Header="Trust" Binding="{Binding TrustStatus}" Width="90" />
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="130" />
                                <DataGridTextColumn Header="Identity" Binding="{Binding Detail}" Width="2.5*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="1" BorderBrush="#D0D7DE" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,10">
                                    <UniformGrid Columns="6" Margin="0,0,0,8">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Application" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedApplication.Name}" FontSize="13" FontWeight="SemiBold" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Process" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedApplication.ProcessName}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Publisher" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedApplication.Publisher}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Signature" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedApplication.SignatureStatus}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Trust" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedApplication.TrustStatus}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Last seen" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedApplication.LastSeen}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="Identity" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedApplication.Detail}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <WrapPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button Content="This is OK" IsEnabled="{Binding CanApplyApplicationTrustDecision}" Width="84" Height="30" Margin="0,0,8,8" Click="OnTrustApplicationClick" />
                                    <Button Content="Keep watching" IsEnabled="{Binding CanApplyApplicationTrustDecision}" Width="104" Height="30" Margin="0,0,8,8" Click="OnWatchApplicationClick" />
                                    <Button Content="Block it" IsEnabled="{Binding CanApplyApplicationTrustDecision}" Width="84" Height="30" Margin="0,0,8,8" Click="OnBlockApplicationClick" />
                                </WrapPanel>
                                <Border Grid.Row="2" Margin="0,4,0,8" Padding="10" Background="#EAF7EF" BorderBrush="#2DA44E" BorderThickness="1" CornerRadius="6" Visibility="{Binding ToastVisibility}">
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right" Content="Dismiss" Width="76" Height="28" Margin="12,0,0,0" Click="OnDismissToastClick" />
                                        <TextBlock Text="{Binding ToastMessage}" Foreground="#1A7F37" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>
                                <Expander Grid.Row="3" Header="Show app protection tools" IsExpanded="False" Margin="0,12,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,8">
                                            <Button Content="Apply protection" IsEnabled="{Binding CanApplyEnforcementPlan}" Width="124" Height="30" Click="OnApplyProtectionClick" />
                                        </WrapPanel>
                                        <TextBlock Text="Protection plan" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding SelectedEnforcementPlan, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontFamily="Consolas" FontSize="12" />
                                    </StackPanel>
                                </Expander>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18" Visibility="{Binding PortsVisibility}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="620" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>
                        <DataGrid Grid.Column="0" ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column" CanUserAddRows="False" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="150" />
                                <DataGridTextColumn Header="Application" Binding="{Binding ApplicationName}" Width="1.4*" />
                                <DataGridTextColumn Header="Zone" Binding="{Binding NetworkZone}" Width="120" />
                                <DataGridTextColumn Header="Reachability" Binding="{Binding ReachabilityTest}" Width="1.4*" />
                                <DataGridTextColumn Header="History" Binding="{Binding HistoryStatus}" Width="1.4*" />
                                <DataGridTextColumn Header="Risk" Binding="{Binding RiskStatus}" Width="90" />
                                <DataGridTextColumn Header="Confidence" Binding="{Binding AppConfidence}" Width="150" />
                                <DataGridTextColumn Header="Next step" Binding="{Binding SuggestedAction}" Width="2*" />
                                <DataGridTextColumn Header="Meaning" Binding="{Binding Meaning}" Width="1.8*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Column="1" BorderBrush="#D0D7DE" BorderThickness="1,0,0,0" Padding="18,0,0,0" Margin="18,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Port details" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                    <TextBlock Text="Endpoint" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedPort.Endpoint}" FontSize="13" FontWeight="SemiBold" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,8" />
                                    <TextBlock Text="Application" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedPort.ApplicationName}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,8" />
                                    <TextBlock Text="Meaning" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedPort.Meaning}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,8" />
                                    <TextBlock Text="Reachability" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedPort.ReachabilityTest}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,8" />
                                    <TextBlock Text="Next step" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedPort.SuggestedAction}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <Button Grid.Row="2" Content="{Binding PortInvestigationButtonText}" IsEnabled="{Binding CanInvestigateSelectedPort}" Width="128" Height="30" HorizontalAlignment="Left" Click="OnInvestigatePortClick" />
                                <Expander Grid.Row="3" Header="Show port investigation" IsExpanded="False" Margin="0,12,0,0">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Investigation result" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding SelectedPortInvestigation, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="120" FontSize="12" />
                                    </StackPanel>
                                </Expander>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18" Visibility="{Binding IncidentsVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Search" FontSize="12" Foreground="#57606A" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding IncidentSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" />
                            <TextBlock Grid.Column="3" Text="Status" FontSize="12" Foreground="#57606A" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="4" ItemsSource="{Binding IncidentStatusFilterOptions}" SelectedItem="{Binding SelectedIncidentStatusFilter, Mode=TwoWay}" Height="30" />
                        </Grid>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Incidents}" SelectedItem="{Binding SelectedIncident, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column" CanUserAddRows="False" BorderThickness="0" MinHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Incident" Binding="{Binding Title}" Width="1.4*" />
                                <DataGridTextColumn Header="Group" Binding="{Binding Grouping}" Width="1.6*" />
                                <DataGridTextColumn Header="Severity" Binding="{Binding SeverityExplanation}" Width="1.7*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                                <DataGridTextColumn Header="Events" Binding="{Binding EventCount}" Width="70" />
                                <DataGridTextColumn Header="Target" Binding="{Binding MainTarget}" Width="1.2*" />
                                <DataGridTextColumn Header="Updated" Binding="{Binding LastUpdated}" Width="130" />
                                <DataGridTextColumn Header="Next" Binding="{Binding RecommendedAction}" Width="1.7*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="2" BorderBrush="#D0D7DE" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <UniformGrid Columns="6" Margin="0,0,0,10">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Incident" FontSize="11" Foreground="#57606A" />
                                        <TextBlock Text="{Binding SelectedIncident.Title}" FontSize="13" FontWeight="SemiBold" Foreground="#24292F" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Target" FontSize="11" Foreground="#57606A" />
                                        <TextBlock Text="{Binding SelectedIncident.MainTarget}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Risk" FontSize="11" Foreground="#57606A" />
                                        <TextBlock Text="{Binding SelectedIncident.RiskLevel}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Status" FontSize="11" Foreground="#57606A" />
                                        <TextBlock Text="{Binding SelectedIncident.Status}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Events" FontSize="11" Foreground="#57606A" />
                                        <TextBlock Text="{Binding SelectedIncident.EventCount}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Updated" FontSize="11" Foreground="#57606A" />
                                        <TextBlock Text="{Binding SelectedIncident.LastUpdated}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                    </StackPanel>
                                </UniformGrid>
                                <StackPanel Grid.Row="1" Margin="0,2,0,10">
                                    <TextBlock Text="Next step" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedIncident.RecommendedAction}" Foreground="#24292F" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <WrapPanel Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button Content="This is OK" IsEnabled="{Binding CanApplyIncidentAction}" Width="84" Height="30" Margin="0,0,8,8" Click="OnResolveIncidentClick" />
                                    <Button Content="Keep watching" IsEnabled="{Binding CanApplyIncidentAction}" Width="108" Height="30" Margin="0,0,8,8" Click="OnWatchIncidentClick" />
                                    <Button Content="Act now" IsEnabled="{Binding CanApplyIncidentAction}" Width="84" Height="30" Margin="0,0,8,8" Click="OnEscalateIncidentClick" />
                                    <Button Content="Review with AI" IsEnabled="{Binding CanReviewIncidentWithAi}" Width="118" Height="30" Margin="0,0,8,8" Click="OnReviewIncidentWithAiClick" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                        <Expander Grid.Row="3" Header="Show investigation details" IsExpanded="False" Margin="0,12,0,0">
                            <StackPanel Margin="0,10,0,0">
                                <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,8">
                                    <Button Content="Make automatic" IsEnabled="{Binding CanApplyIncidentAction}" Width="120" Height="30" Margin="0,0,8,8" Click="OnCreateIncidentRuleClick" />
                                    <Button Content="Save notes" IsEnabled="{Binding CanSaveIncidentNotes}" Width="96" Height="30" Margin="0,0,8,8" Click="OnSaveIncidentNotesClick" />
                                    <Button Content="Export" IsEnabled="{Binding CanExportIncident}" Width="76" Height="30" Margin="0,0,8,8" Click="OnExportIncidentClick" />
                                    <Button Content="Copy for ChatGPT" IsEnabled="{Binding HasIncidentAiReview}" Width="126" Height="30" Margin="0,0,0,8" Click="OnCopyIncidentForChatGptClick" />
                                </WrapPanel>
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Why AccessWatch flagged it" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentExplanation, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Timeline" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentTimeline, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Evidence" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentEvidence, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Notes" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="Rule wizard" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentRuleWizard, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontFamily="Consolas" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="4">
                                    <TextBlock Text="Export" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentExport, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontFamily="Consolas" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="0">
                                    <TextBlock Text="Severity explanation" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentSeverityExplanation, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="2">
                                    <TextBlock Text="AI review" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentAiReview, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontFamily="Consolas" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="4">
                                    <TextBlock Text="Rule suggestion" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedIncidentRuleSuggestion, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="76" FontFamily="Consolas" FontSize="12" />
                                </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Expander>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18" Visibility="{Binding RulesVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DataGrid Grid.Row="0" ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column" CanUserAddRows="False" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Rule" Binding="{Binding Name}" Width="1.4*" />
                                <DataGridTextColumn Header="State" Binding="{Binding Enabled}" Width="90" />
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120" />
                                <DataGridTextColumn Header="Risk" Binding="{Binding RiskLevel}" Width="90" />
                                <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="1.3*" />
                                <DataGridTextColumn Header="Conditions" Binding="{Binding Conditions}" Width="2*" />
                                <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="150" />
                                <DataGridTextColumn Header="Network" Binding="{Binding NetworkProfile}" Width="130" />
                                <DataGridTextColumn Header="Notifications" Binding="{Binding QuietHours}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560" Visibility="{Binding RulesEmptyVisibility}">
                            <StackPanel>
                                <TextBlock Text="No rules yet" FontSize="18" FontWeight="SemiBold" Foreground="#24292F" HorizontalAlignment="Center" />
                                <TextBlock Text="Rules appear here after you create a rule from an incident. AccessWatch keeps new rules disabled first, so you can preview what they affect before enabling them." Margin="0,8,0,0" FontSize="13" Foreground="#57606A" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" BorderBrush="#D0D7DE" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,10">
                                    <UniformGrid Columns="6" Margin="0,0,0,8">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Rule" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedRule.Name}" FontSize="13" FontWeight="SemiBold" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="State" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedRule.Enabled}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Action" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedRule.Action}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Risk" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedRule.RiskLevel}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Network" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedRule.NetworkProfile}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Duration" FontSize="11" Foreground="#57606A" />
                                            <TextBlock Text="{Binding SelectedRule.Duration}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="Conditions" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedRule.Conditions}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,6" />
                                    <TextBlock Text="Description" FontSize="11" Foreground="#57606A" />
                                    <TextBlock Text="{Binding SelectedRule.Description}" FontSize="13" Foreground="#24292F" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <WrapPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button Content="Preview" IsEnabled="{Binding CanApplyRuleAction}" Width="76" Height="30" Margin="0,0,8,8" Click="OnPreviewRuleClick" />
                                    <Button Content="Enable" IsEnabled="{Binding CanApplyRuleAction}" Width="76" Height="30" Margin="0,0,8,8" Click="OnEnableRuleClick" />
                                    <Button Content="Disable" IsEnabled="{Binding CanApplyRuleAction}" Width="76" Height="30" Margin="0,0,0,8" Click="OnDisableRuleClick" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                        <Expander Grid.Row="2" Header="Show rule details" IsExpanded="False" Margin="0,12,0,0">
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rule preview" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedRulePreview, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="96" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="AI summary" FontSize="11" Foreground="#57606A" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding SelectedRule.AiSummary, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="96" FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Expander>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18" Visibility="{Binding SettingsVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Protection mode" FontSize="14" FontWeight="SemiBold" Foreground="#24292F" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding ProtectionModeOptions}" SelectedValue="{Binding SelectedProtectionMode, Mode=TwoWay}" SelectedValuePath="Value" DisplayMemberPath="Name" Height="32" MinWidth="260" HorizontalAlignment="Left" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="AI review" FontSize="14" FontWeight="SemiBold" Foreground="#24292F" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding AiModeOptions}" SelectedValue="{Binding SelectedAiMode, Mode=TwoWay}" SelectedValuePath="Value" DisplayMemberPath="Name" Height="32" MinWidth="260" HorizontalAlignment="Left" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Quiet hours" FontSize="14" FontWeight="SemiBold" Foreground="#24292F" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding QuietHoursOptions}" SelectedValue="{Binding SelectedQuietHours, Mode=TwoWay}" SelectedValuePath="Value" DisplayMemberPath="Name" Height="32" MinWidth="260" HorizontalAlignment="Left" />
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Network profile" FontSize="14" FontWeight="SemiBold" Foreground="#24292F" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding NetworkProfileOptions}" SelectedValue="{Binding SelectedNetworkProfile, Mode=TwoWay}" SelectedValuePath="Value" DisplayMemberPath="Name" Height="32" MinWidth="260" HorizontalAlignment="Left" />
                        </Grid>

                        <Grid Grid.Row="4" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Support bridge" FontSize="14" FontWeight="SemiBold" Foreground="#24292F" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding SelectedSupportBridgeEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32" MinWidth="420" HorizontalAlignment="Left" />
                        </Grid>

                        <StackPanel Grid.Row="5">
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Running protection" FontSize="12" Foreground="#57606A" />
                                    <TextBlock Text="{Binding CurrentProtectionMode}" FontSize="18" FontWeight="SemiBold" Foreground="#24292F" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Running AI review" FontSize="12" Foreground="#57606A" />
                                    <TextBlock Text="{Binding CurrentAiMode}" FontSize="18" FontWeight="SemiBold" Foreground="#24292F" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding SettingsStatus}" Foreground="#57606A" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Apply settings" Width="120" Height="32" Margin="0,0,8,0" Click="OnApplySettingsClick" />
                                <Button Content="Reset" Width="88" Height="32" Click="OnResetSettingsClick" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="24" Visibility="{Binding PlaceholderVisibility}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="This section is next." FontSize="18" FontWeight="SemiBold" Foreground="#24292F" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedPageSummary}" FontSize="13" Foreground="#57606A" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
