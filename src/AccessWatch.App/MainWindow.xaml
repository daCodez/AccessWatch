<Window x:Class="AccessWatch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AccessWatch" Height="560" Width="960" MinHeight="480" MinWidth="760"
        Background="#F6F8FA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="0,0,0,1" Padding="20,14">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="AccessWatch" FontSize="22" FontWeight="SemiBold" Foreground="#24292F" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#2DA44E" Margin="0,0,8,0" />
                    <TextBlock Text="Ready" Foreground="#57606A" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="0,0,1,0" Padding="12">
                <ListBox ItemsSource="{Binding Pages}"
                         SelectedIndex="0"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="10,8" FontSize="14" Foreground="#24292F" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Column="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock Text="Overview" FontSize="26" FontWeight="SemiBold" Foreground="#24292F" />
                    <TextBlock Text="Listening ports, app identities, and recent events will appear here as the service records them."
                               Margin="0,6,0,0" FontSize="14" Foreground="#57606A" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Recent activity" FontSize="18" FontWeight="SemiBold" Foreground="#24292F" />
                        <TextBlock Grid.Row="1" Text="No recent events loaded." FontSize="15" Foreground="#57606A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>

